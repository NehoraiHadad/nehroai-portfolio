---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nehorai Hadad",
  description = "Welcome — pick a world to explore.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://nehoraihadad.com");
const ogImage = new URL("/brand/cover.png", Astro.site ?? "https://nehoraihadad.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/brand/monogram.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical.href} />
    <meta name="theme-color" content="#050E22" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / share -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
  </head>
  <body data-world="portfolio">
    <div class="bg-glow" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>
    <slot />
  </body>
</html>
