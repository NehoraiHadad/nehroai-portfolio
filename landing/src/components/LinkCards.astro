---
/** Container that maps over the data-driven LINKS list. */
import LinkCard from "./LinkCard.astro";
import { LINKS } from "../lib/links";
---

<nav class="link-cards" aria-label="Where to go next">
  {LINKS.map((link) => <LinkCard link={link} />)}
</nav>

<style>
  /* Mobile: a stack. Desktop: a row so all three worlds stay on-screen and
     the active one can spotlight in place as the character cycles worlds. */
  .link-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
    width: min(94vw, 440px);
    margin-inline: auto;
  }

  @media (min-width: 720px) {
    .link-cards {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-5);
      width: min(96vw, 960px);
      align-items: stretch;
    }
  }
</style>
