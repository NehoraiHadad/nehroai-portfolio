# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for the contact form to send emails (https://resend.com/api-keys).
RESEND_API_KEY=""

# CONTACT_FROM_EMAIL: Optional sender address. Must be from a verified Resend domain.
# Defaults to "Portfolio Contact <onboarding@resend.dev>" (Resend's shared sender,
# which only delivers to the Resend account owner's email until a domain is verified).
CONTACT_FROM_EMAIL=""

# CONTACT_TO_EMAIL: Optional recipient override. Defaults to nehorai.hadad@gmail.com.
CONTACT_TO_EMAIL=""

# ─────────────────────────────────────────────────────────────────────────────
# Admin app (admin.nehoraihadad.com) — Auth.js v5 (NextAuth) + Google login.
# ─────────────────────────────────────────────────────────────────────────────

# AUTH_SECRET: Secret used to encrypt the session JWT. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=""

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: Google OAuth 2.0 Web client credentials.
# Create at https://console.cloud.google.com/apis/credentials (OAuth client ID,
# type "Web application"). Authorized redirect URIs:
#   https://admin.nehoraihadad.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ADMIN_EMAILS: Comma-separated allowlist of Google account emails permitted
# into the admin area. Everyone else is denied at sign-in.
#   e.g. ADMIN_EMAILS="nehorai.hadad@gmail.com,partner@example.com"
ADMIN_EMAILS=""

# AUTH_URL: Public base URL of the admin app (used by Auth.js behind the proxy).
AUTH_URL="https://admin.nehoraihadad.com"

# AUTH_TRUST_HOST: Required when running behind a proxy / custom host (Vercel).
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────────────────────
# Admin database — Neon Postgres (Drizzle ORM). Quotes/brand persistence.
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL: Neon Postgres connection string. Create the database via
# Vercel → Storage → Neon (Marketplace), attached to this project; Vercel injects
# this var automatically in prod. For local dev, copy the connection string here.
# Schema is applied with `pnpm db:push`.
DATABASE_URL=""
