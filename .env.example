# GEMINI_API_KEY: Powers the public portfolio chat (/api/portfolio-chat) via
# Gemini 2.5 Flash. Create at https://aistudio.google.com/apikey. Without it the
# chat route returns 503 and the UI shows a graceful fallback message.
GEMINI_API_KEY=""

# CHAT_RATE_LIMIT_SALT: Optional salt for the hashed-IP chat rate limiter.
# Falls back to a constant in code — set a random secret in production so the
# stored IP hashes cannot be reversed by enumerating the IPv4 space.
CHAT_RATE_LIMIT_SALT=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for the contact form to send emails (https://resend.com/api-keys).
RESEND_API_KEY=""

# CONTACT_FROM_EMAIL: Optional sender address. Must be from a verified Resend domain.
# Defaults to "Portfolio Contact <onboarding@resend.dev>" (Resend's shared sender,
# which only delivers to the Resend account owner's email until a domain is verified).
CONTACT_FROM_EMAIL=""

# CONTACT_TO_EMAIL: Optional recipient override. Defaults to nehorai.hadad@gmail.com.
CONTACT_TO_EMAIL=""

# ─────────────────────────────────────────────────────────────────────────────
# Admin app (admin.nehoraihadad.com) — Auth.js v5 (NextAuth) + Google login.
# ─────────────────────────────────────────────────────────────────────────────

# AUTH_SECRET: Secret used to encrypt the session JWT. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=""

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: Google OAuth 2.0 Web client credentials.
# Create at https://console.cloud.google.com/apis/credentials (OAuth client ID,
# type "Web application"). Authorized redirect URIs:
#   https://admin.nehoraihadad.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ADMIN_EMAILS: Comma-separated allowlist of Google account emails permitted
# into the admin area. Everyone else is denied at sign-in.
#   e.g. ADMIN_EMAILS="nehorai.hadad@gmail.com,partner@example.com"
ADMIN_EMAILS=""

# AUTH_URL: Public base URL of the admin app (used by Auth.js behind the proxy).
AUTH_URL="https://admin.nehoraihadad.com"

# PUBLIC_APP_ORIGIN: Origin of the PUBLIC app host that serves client-facing
# pages — specifically the quote approval page /q/<token>. This is NOT the admin
# subdomain: proxy.ts redirects every non-/admin path on admin.* to the
# dashboard, so share links must use the public host instead. Used to build
# share links in the UI, the agent HTTP route, and the MCP tool. If unset, those
# fall back to the request host (fine for localhost dev, wrong in prod).
#   e.g. PUBLIC_APP_ORIGIN="https://ai.nehoraihadad.com"
PUBLIC_APP_ORIGIN="https://ai.nehoraihadad.com"

# AUTH_TRUST_HOST: Required when running behind a proxy / custom host (Vercel).
AUTH_TRUST_HOST="true"

# ─────────────────────────────────────────────────────────────────────────────
# Admin database — Neon Postgres (Drizzle ORM). Quotes/brand persistence.
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL: Neon Postgres connection string. Create the database via
# Vercel → Storage → Neon (Marketplace), attached to this project; Vercel injects
# this var automatically in prod. For local dev, copy the connection string here.
# Schema is applied with `pnpm db:push`.
DATABASE_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# PDF generation — headless Chromium (admin quote PDF download).
# ─────────────────────────────────────────────────────────────────────────────

# LOCAL_CHROME_PATH: Path to the Chrome executable used by puppeteer-core for
# local development PDF generation. Only needed locally — on Vercel the route
# uses @sparticuz/chromium-min + a downloaded pack (see below). Defaults to the
# standard Windows Chrome path if unset.
#   macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux example: /usr/bin/google-chrome
LOCAL_CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# CHROMIUM_PACK_URL: (optional, prod) URL of the @sparticuz/chromium pack tar the
# serverless route downloads at runtime. Defaults to the official GitHub release
# for the installed chromium-min version. Override to self-host the pack (e.g. on
# Vercel Blob in-region) for faster cold starts. MUST match the installed
# @sparticuz/chromium-min version.
# CHROMIUM_PACK_URL="https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.x64.tar"
